# ── LLM provider ─────────────────────────────────────────────
# "ollama" (free, local), "nvidia" (free hosted tier), or "anthropic" (best quality)
LLM_PROVIDER=ollama

# Anthropic (only needed when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Ollama (only needed when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# NVIDIA NIM (only needed when LLM_PROVIDER=nvidia) — get a key at build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash
# Optional JSON merged into each request (model-specific reasoning options etc.):
NVIDIA_EXTRA_BODY={"chat_template_kwargs": {"thinking": true, "reasoning_effort": "high"}}

# ── Telegram ─────────────────────────────────────────────────
# Create a bot with @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs allowed to talk to Sirius (empty = allow all).
# Send /id to the bot to discover your chat id.
TELEGRAM_ALLOWED_CHAT_IDS=

# ── API ──────────────────────────────────────────────────────
# Shared secret for the REST API (sent as X-API-Key header). Empty = open API.
SIRIUS_API_KEY=
HOST=0.0.0.0
PORT=8000

# ── Storage ──────────────────────────────────────────────────
DATA_DIR=data
DATABASE_URL=sqlite:///data/sirius.db

# ── Misc ─────────────────────────────────────────────────────
TIMEZONE=Asia/Taipei
# Fernet key for encrypting sensitive memories. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
